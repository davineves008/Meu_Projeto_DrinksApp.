<UserControl x:Class="Projeto_DrinksApp.Uc_CriarProduto"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Projeto_DrinksApp"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="600">

    <Grid Margin="30">
        <StackPanel>
            <Button x:Name="BtnVoltar" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent" Click="BtnVoltar_Click" Cursor="Hand" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="#FF00F9FF" Width="18" Height="18" Stretch="Fill"/>
                    <TextBlock Text="Voltar" Foreground="#FF00F9FF" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>
                </StackPanel>
            </Button>

            <TextBlock Text="Cadastrar Novo Produto" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

            <Border Background="#11FFFFFF" Padding="20" CornerRadius="10" BorderBrush="#22FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Nome do Produto" Foreground="#88FFFFFF" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNomeProduto" Height="35" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="5"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Preço (R$)" Foreground="#88FFFFFF" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtPreco" Height="35" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" VerticalContentAlignment="Center" Padding="5"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Categoria" Foreground="#88FFFFFF" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbCategoria" Height="35" Background="#111111" Foreground="Black" BorderBrush="#44FFFFFF">
                                <ComboBoxItem Content="Cerveja"/>
                                <ComboBoxItem Content="Whisky"/>
                                <ComboBoxItem Content="Vinho"/>
                                <ComboBoxItem Content="Lanches"/>
                                <ComboBoxItem Content="Destilados"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Caminho da Imagem (URL ou Local)" Foreground="#88FFFFFF" Margin="0,15,0,5"/>
                    <TextBox x:Name="txtImagem" Height="35" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Margin="0,0,0,20" VerticalContentAlignment="Center" Padding="5"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnSalvarProduto" 
            Grid.Column="0"
            Content="SALVAR" 
            Click="btnSalvarProduto_Click"
            Height="45" 
            Background="#FF00F9FF" 
            Foreground="Black" 
            FontWeight="Bold" 
            Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button x:Name="btnExcluirProduto" 
            Grid.Column="2"
            Content="EXCLUIR" 
            Click="btnExcluirProduto_Click"
            Height="45" 
            Background="#FFFF4444" 
            Foreground="White" 
            FontWeight="Bold" 
            Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>