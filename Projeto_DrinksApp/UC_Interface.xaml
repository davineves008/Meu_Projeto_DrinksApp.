<UserControl x:Class="Projeto_DrinksApp.UC_Interface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <TextBlock Text="Personalização" FontSize="24" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,5"/>
            <TextBlock Text="Ajuste as cores, temas e comportamentos visuais do sistema." FontSize="12" Foreground="#666666" Margin="0,0,0,30"/>

            <Separator Height="1" Background="#DDDDDD" Margin="0,0,0,20"/>

            <TextBlock Text="Aparência" FontSize="16" FontWeight="Medium" Margin="0,0,0,15"/>

            <StackPanel Margin="10,0,0,20">
                <TextBlock Text="Escolha o seu tema preferido:" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="rbClaro" Content="Modo Claro" IsChecked="True" Margin="0,0,20,0" Checked="rbTema_Checked"/>
                    <RadioButton x:Name="rbEscuro" Content="Modo Escuro" Checked="rbTema_Checked"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="10,0,0,20">
                <TextBlock Text="Cor de Destaque (Accent Color)" Margin="0,0,0,10"/>
                <WrapPanel>
                    <Button Width="30" Height="30" Background="RoyalBlue" Margin="0,0,5,0" Cursor="Hand" Click="btnColor_Click"/>
                    <Button Width="30" Height="30" Background="Crimson" Margin="0,0,5,0" Cursor="Hand" Click="btnColor_Click"/>
                    <Button Width="30" Height="30" Background="SeaGreen" Margin="0,0,5,0" Cursor="Hand" Click="btnColor_Click"/>
                    <Button Width="30" Height="30" Background="Orange" Margin="0,0,5,0" Cursor="Hand" Click="btnColor_Click"/>
                </WrapPanel>
            </StackPanel>

            <Separator Height="1" Background="#DDDDDD" Margin="0,20,0,20"/>

            <TextBlock Text="Regional" FontSize="16" FontWeight="Medium" Margin="0,0,0,15"/>

            <Grid Margin="10,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Idioma do Sistema" FontWeight="SemiBold"/>
                    <TextBlock Text="Altera o idioma de menus e botões." FontSize="11" Foreground="#888888"/>
                </StackPanel>

                <ComboBox x:Name="cmbIdioma" Grid.Column="1" Height="25" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Português (Brasil)" IsSelected="True"/>
                    <ComboBoxItem Content="English (USA)"/>
                    <ComboBoxItem Content="Español"/>
                </ComboBox>
            </Grid>

            <Button Content="Salvar Alterações" x:Name="btnSalvar"
                    Click="btnSalvar_Click"
                    Background="#0078D7" 
                    Foreground="White" 
                    Width="150" 
                    Height="35" 
                    HorizontalAlignment="Right"
                    Margin="0,30,0,0"
                    BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>