<UserControl x:Class="Projeto_DrinksApp.UC_Seguranca"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="600">
    <Grid>
        <StackPanel Margin="20">

            <Button x:Name="BtnVoltar" 
                    HorizontalAlignment="Left" 
                    Margin="0,0,0,20" 
                    Background="Transparent" 
                    BorderBrush="Transparent" 
                    Cursor="Hand"
                    Click="BtnVoltar_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                          Fill="{DynamicResource CorDestaqueDinamica}" 
                          Width="18" Height="18" Stretch="Fill"/>
                    <TextBlock Text="Voltar " 
                               Foreground="{DynamicResource CorDestaqueDinamica}" 
                               VerticalAlignment="Center" 
                               Margin="10,0,0,0" 
                               FontSize="14" 
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <TextBlock Text="Segurança da Conta" FontSize="18" Foreground="#FF00F9FF" Margin="0,0,0,15"/>

            <Border Background="#11FFFFFF" Padding="15" CornerRadius="10" Margin="0,0,0,25" BorderBrush="#22FFFFFF" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Alterar Senha" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Senha Atual" Foreground="#88FFFFFF" FontSize="11" Margin="5,0,0,3"/>
                    <PasswordBox x:Name="txtSenhaAtual" Background="#22FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" Padding="5" Height="30" Margin="0,0,0,10"/>

                    <TextBlock Text="Nova Senha" Foreground="#88FFFFFF" FontSize="11" Margin="5,0,0,3"/>
                    <Grid Margin="0,0,0,15">
                        <PasswordBox x:Name="txtSenhaNova" Background="#22FFFFFF" Foreground="White" 
                                     BorderThickness="1" BorderBrush="#44FFFFFF" Padding="5,5,35,5" Height="30"/>

                        <TextBox x:Name="txtSenhaRevelada" Background="#22FFFFFF" Foreground="White" 
                                 BorderThickness="1" BorderBrush="#00F9FF" Padding="5,5,35,5" Height="30" 
                                 Visibility="Collapsed"/>

                        <ToggleButton x:Name="btnRevelarSenha" HorizontalAlignment="Right" Width="30" 
                                      Background="Transparent" BorderBrush="Transparent" 
                                      Click="btnRevelarSenha_Click" Cursor="Hand">
                            <Path x:Name="iconOlho" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" 
                                  Fill="#88FFFFFF" Stretch="Fill" Width="18" Height="12"/>
                        </ToggleButton>
                    </Grid>

                    <Button x:Name="btnAtualizarSenha" Click="btnAtualizarSenha_Click" Content="Atualizar Senha" Background="#FF00F9FF" Foreground="Black" FontWeight="Bold" Width="140" Height="30" HorizontalAlignment="Right" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Text="Zona de Perigo" FontSize="18" Foreground="#FFFF4545" Margin="0,10,0,15"/>

            <Border Background="#11FF0000" Padding="15" CornerRadius="10" BorderBrush="#33FF0000" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Excluir Conta Permanentemente" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="Ao confirmar, todos os seus dados e histórico serão removidos e você será deslogado imediatamente." 
                               Foreground="#AAFFFFFF" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,15"/>

                    <Button x:Name="btnExcluirConta" Content="EXCLUIR MINHA CONTA" Click="btnExcluirConta_Click"
                            Background="Transparent" Foreground="#FFFF4545" BorderBrush="#FFFF4545" 
                            BorderThickness="1" FontWeight="Bold" Height="35" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="17"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>