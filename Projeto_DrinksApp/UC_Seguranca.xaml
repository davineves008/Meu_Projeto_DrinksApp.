<UserControl x:Class="Projeto_DrinksApp.UC_Seguranca"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Projeto_DrinksApp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Segurança da Conta" FontSize="18" Foreground="#FF00F9FF" Margin="0,0,0,15"/>

            <Border Background="#11FFFFFF" Padding="15" CornerRadius="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Alterar Senha" Foreground="White" FontWeight="Bold"/>
                    <PasswordBox x:Name="txtSenhaAtual" Margin="0,10,0,5" Tag="Senha Atual"/>
                    <PasswordBox x:Name="txtSenhaNova" Margin="0,5,0,10"/>
                    <Button Content="Atualizar Senha" Background="#FF00F9FF" Foreground="Black" Width="120" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Privacidade e Dados" FontSize="18" Foreground="#FF00F9FF" Margin="0,10,0,15"/>
            <Button Content="Limpar meu histórico de compras" Background="Transparent" Foreground="Red" BorderBrush="Red"/>
            <TextBlock Text="Isso removerá permanentemente seus pedidos do nosso banco." Foreground="#66FFFFFF" FontSize="10" Margin="5,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
