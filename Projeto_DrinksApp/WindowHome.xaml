<Window x:Class="Projeto_DrinksApp.WindowHome"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Closing="Window_Closing"
        Title="DrinksApp - Home" 
        Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter x:Name="content" Opacity="0.8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="content" Property="Opacity" Value="1"/>
                                <Setter TargetName="content" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="20,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Txt_Pesquisa, Path=IsFocused}" Value="True">
                    <Setter Property="BorderBrush" Value="#FF00F9FF"/>
                    <Setter Property="Background" Value="#44FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="0"/>
                <GradientStop Color="#FF2638A2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="DrinksApps" 
               Grid.Column="0" Grid.Row="0" 
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               Foreground="#FF00F9FF" 
               FontFamily="Bahnschrift SemiBold Condensed" FontSize="22"/>

        <StackPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Margin="15,20,10,0">
            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnHome_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Fill="#FF00F9FF" Width="18" Height="18" Stretch="Fill"/>
                    <TextBlock Text="Home" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnPerfil_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
              Fill="#FF00F9FF" Width="18" Height="18" Stretch="Fill"/>
                    <TextBlock Text="Perfil" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                </StackPanel>
            </Button>

            <Separator Background="#33FFFFFF" Margin="5,15"/>

            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnPedidos_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M7,15H17V17H7V15M7,11H17V13H7V11M7,7H17V9H7V7M18,3H6A2,2 0 0,0 4,5V19A2,2 0 0,0 6,21H18A2,2 0 0,0 20,19V5A2,2 0 0,0 18,3Z" Fill="#FF00F9FF" Width="18" Height="18" Stretch="Fill"/>
                    <TextBlock Text="Pedidos" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnConfig_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.35 19.43,11.03L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.52,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.03C4.53,11.35 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.35 8.52,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.48,18.68 16.04,18.35 16.56,17.95L19.05,18.93C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
              Fill="#FF00F9FF" 
              Width="18" 
              Height="18" 
              Stretch="Fill"/>
                    <TextBlock Text="Config." 
                   Foreground="White" 
                   VerticalAlignment="Center" 
                   Margin="12,0,0,0" 
                   FontSize="14"/>
                </StackPanel>
            </Button>

            <Separator Background="#33FFFFFF" Margin="5,15"/>

            <Button Style="{StaticResource MenuButtonStyle}" Click="BtnSair_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M16,17V14H9V10H16V7L21,12L16,17M14,2A2,2 0 0,1 16,4V6H14V4H5V20H14V18H16V20A2,2 0 0,1 14,22H5A2,2 0 0,1 3,20V4A2,2 0 0,1 5,2H14Z" Fill="#FF00F9FF" Width="18" Height="18" Stretch="Fill"/>
                    <TextBlock Text="Sair" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Column="1" Grid.Row="0" Margin="10,0,25,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Height="25" Width="30" Source="/do-utilizador.png"/>
                <Image Height="26" Width="30" Source="/localizacao.png" Margin="15,0,5,0"/>
                <TextBox x:Name="Txt_Endereco" 
         Text="" 
         Width="180" 
         Background="Transparent" 
         Foreground="#FF00F9FF" 
         BorderBrush="Transparent" 
         VerticalAlignment="Center" 
         FontSize="11"
         TextWrapping="NoWrap"
         MaxLength="100"/>

                <Border Style="{StaticResource SearchBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.01,15.14C11.87,16.11 10.39,16.7 8.75,16.7A7.75,7.75 0 0,1 1,8.95A7.75,7.75 0 0,1 8.75,1.2M9.5,5A4.5,4.5 0 0,0 5,9.5A4.5,4.5 0 0,0 9.5,14A4.5,4.5 0 0,0 14,9.5A4.5,4.5 0 0,0 9.5,5Z" 
                              Fill="#FF00F9FF" Stretch="Uniform" Width="16" Height="16" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBox x:Name="Txt_Pesquisa" Grid.Column="1"  Background="Transparent" BorderBrush="Transparent" Foreground="White" VerticalAlignment="Center" Margin="5,0,10,0" FontSize="13" GotFocus="Txt_Pesquisa_GotFocus" LostFocus="Txt_Pesquisa_LostFocus" TextChanged="Txt_Pesquisa_TextChanged"/>
                        <Popup x:Name="PopupSugestoes" 
       PlacementTarget="{Binding ElementName=Txt_Pesquisa}" 
       Placement="Bottom"
       AllowsTransparency="True"
       PopupAnimation="Slide"
       StaysOpen="False">

                            <Border Background="#252525" 
            BorderBrush="#FF00F9FF" 
            BorderThickness="2" 
            Width="300" 
            MinHeight="50">
                                <ListBox x:Name="ListSugestoes" 
         SelectionChanged="ListSugestoes_SelectionChanged"
         Background="Transparent" 
         BorderThickness="0"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Name="Border" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Border" Property="Background" Value="#33FF00F9"/>
                                                                <Setter Property="Foreground" Value="#FF00F9FF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Border" Property="Background" Value="#FF00F9FF"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔍" 
                           Margin="0,0,10,0" 
                           FontSize="12" 
                           VerticalAlignment="Center" 
                           Opacity="0.6"/>

                                                <TextBlock Text="{Binding Nome}" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </StackPanel>

            <Button HorizontalAlignment="Right" Click="BtnAbrirCarrinho_Click" Background="Transparent" BorderBrush="Transparent" Cursor="Hand" VerticalAlignment="Center">
                <Grid>
                    <Path Data="M7,18c-1.1,0-1.99,0.9-1.99,2S5.9,22,7,22s2-0.9,2-2S8.1,18,7,18z M1,2v2h2l3.6,7.59L5.25,15c-0.15,0.34-0.25,0.71-0.25,1 c0,1.1,0.9,2,2,2h12v-2H7.42c-0.14,0-0.25-0.11-0.25-0.25l0.03-0.12L8.1,13h7.45c0.75,0,1.41-0.41,1.75-1.03l3.58-6.49 C21.1,5.21,20.94,5,20.7,5H5.21L4.27,3H1V2H1z M17,18c-1.1,0-1.99,0.9-1.99,2s0.89,2,1.99,2s2-0.9,2-2S18.1,18,17,18z" 
                          Fill="#FF00F9FF" Stretch="Fill" Width="28" Height="28"/>
                    <Border Background="Red" CornerRadius="10" MinWidth="18" Height="18" Margin="15,-10,0,0" VerticalAlignment="Top" HorizontalAlignment="Right">
                        <TextBlock x:Name="Txt_ContadorCarrinho" Text="0" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0"/>
                    </Border>
                </Grid>
            </Button>
        </Grid>

        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
            <Button Click="BtnCerveja_Click" Style="{StaticResource MenuButtonStyle}" Margin="15,0">
                <StackPanel>
                    <Image Source="C:\Users\06233321085\Pictures\brahma-removebg-preview.png" Width="60" Height="40"/>
                    <TextBlock Text="Cervejas" HorizontalAlignment="Center" Foreground="#FF00F9FF" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button Click="BtnWhisky_Click" Style="{StaticResource MenuButtonStyle}" Margin="15,0">
                <StackPanel>
                    <Image Source="C:\Users\06233321085\Pictures\download-removebg-preview.png" Width="60" Height="40"/>
                    <TextBlock Text="Whisky" HorizontalAlignment="Center" Foreground="#FF00F9FF" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button Click="BtnLanches_Click" Style="{StaticResource MenuButtonStyle}" Margin="15,0">
                <StackPanel>
                    <Image Source="C:\Users\06233321085\Pictures\xis_Burguer-removebg-preview.png" Width="60" Height="40"/>
                    <TextBlock Text="Lanches" HorizontalAlignment="Center" Foreground="#FF00F9FF" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button Click="BtnVinhos_Click" Style="{StaticResource MenuButtonStyle}" Margin="15,0">
                <StackPanel>
                    <Image Source="C:\Users\06233321085\Pictures\vinhos-removebg-preview.png" Width="60" Height="40"/>
                    <TextBlock Text="Vinhos" HorizontalAlignment="Center" Foreground="#FF00F9FF" FontSize="12"/>
                </StackPanel>
            </Button>
        </StackPanel>
        

        <ContentControl Grid.Column="1" Grid.Row="2" 
                        x:Name="ConteudoPrincipal" 
                        Margin="10,0,10,10"/>
    </Grid>
    
</Window>