<UserControl x:Class="Projeto_DrinksApp.UC_Lanches"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="350" Width="600">
    <UserControl.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black" Offset="0"/>
            <GradientStop Color="#FF63320D" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="MENU DE LANCHES" Foreground="#FFFF8C00" FontSize="24" HorizontalAlignment="Center" FontFamily="Sitka Subheading"/>
                <TextBlock Text="Hambúrgueres e Porções" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,25"/>
                <WrapPanel HorizontalAlignment="Center">
                    <Border Background="#44000000" CornerRadius="10" Width="140" Height="190" Margin="10" BorderBrush="#FFFF8C00" BorderThickness="1">
                        <StackPanel>
                            <Image Source="C:\Users\Usuario\OneDrive\Imagens/lanches-removebg-preview.png" Height="90" Margin="5"/>
                            <TextBlock Text="X-Burguer" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock Text="R$ 22,90" Foreground="#FFFF8C00" HorizontalAlignment="Center" Margin="5"/>
                            <Button Content="Comprar" Click="BtnComprar_Click" Tag="X-Burguer" Uid="22.90" Background="#FFFF8C00" Foreground="White" Width="100" Margin="5"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>