<UserControl x:Class="Projeto_DrinksApp.UC_Perfil"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="Meu Perfil" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
            <TextBlock Text="Gerencie suas informações e histórico de pedidos." Foreground="#88FFFFFF" Margin="0,0,0,25"/>

            <Separator Height="1" Background="#33FFFFFF" Margin="0,0,0,25"/>

            <TextBlock Text="Dados Pessoais" FontSize="16" FontWeight="SemiBold" Foreground="#FF00F9FF" Margin="0,0,0,15"/>

            <UniformGrid Columns="2" Margin="0,0,0,20">
                <StackPanel Margin="5">
                    <TextBlock Text="Nome Completo" Foreground="#88FFFFFF" FontSize="11" Margin="5,0,0,3"/>
                    <TextBox x:Name="txtNome" Text="João Silva" Background="#22FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" Padding="8" Height="35"/>
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="E-mail" Foreground="#88FFFFFF" FontSize="11" Margin="5,0,0,3"/>
                    <TextBox x:Name="txtEmail" Text="joao@exemplo.com" Background="#22FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" Padding="8" Height="35"/>
                </StackPanel>
            </UniformGrid>

            <TextBlock Text="Endereço de Entrega" FontSize="16" FontWeight="SemiBold" Foreground="#FF00F9FF" Margin="0,10,0,15"/>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Logradouro (Rua, Av.)" Foreground="#88FFFFFF" FontSize="11" Margin="5,0,0,3"/>
                    <TextBox x:Name="txtEndereco" Text="Rua das Flores, 123" Background="#22FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" Padding="8" Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Cidade" Foreground="#88FFFFFF" FontSize="11" Margin="5,0,0,3"/>
                    <TextBox x:Name="txtCidade" Text="Taquara" Background="#22FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" Padding="8" Height="35"/>
                </StackPanel>
            </Grid>

            <Separator Height="1" Background="#33FFFFFF" Margin="0,15,0,25"/>

            <TextBlock Text="Último Pedido Realizado" FontSize="16" FontWeight="SemiBold" Foreground="#FF00F9FF" Margin="0,0,0,15"/>

            <Border Background="#11FFFFFF" CornerRadius="8" Padding="15" BorderBrush="#22FFFFFF" BorderThickness="1">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="lblUltimoPedido" 
           Text="Combo Cerveja Brahma (12 un) + Gelo" 
           Foreground="White" 
           FontWeight="Medium" 
           FontSize="14"/>
                        <TextBlock Text="Entregue em: 12/03/2026" Foreground="#66FFFFFF" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Text="R$ 89,90" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#FF00F9FF" FontSize="18" FontWeight="Bold"/>
                </Grid>
            </Border>

            <Button x:Name="btnSalvarPerfil" Content="Salvar Alterações" Click="btnSalvarPerfil_Click"
                    Background="#FF00F9FF" Foreground="Black" FontWeight="Bold"
                    Width="180" Height="42" HorizontalAlignment="Right" Margin="0,35,0,0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="21"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>