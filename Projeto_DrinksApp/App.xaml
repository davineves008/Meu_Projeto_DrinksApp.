<Application x:Class="Projeto_DrinksApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Projeto_DrinksApp"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <LinearGradientBrush x:Key="FundoGradientDinamico" EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black" Offset="0"/>
            <GradientStop Color="#FF2638A2" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CorDestaqueDinamica" Color="#FF00F9FF" />
        <SolidColorBrush x:Key="CorTextoDinamica" Color="White" />
    </Application.Resources>
</Application>
