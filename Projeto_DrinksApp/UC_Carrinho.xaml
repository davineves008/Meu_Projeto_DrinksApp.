<UserControl x:Class="Projeto_DrinksApp.UC_Carrinho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="358" Width="417">

    <Grid Margin="20">
        <Border Background="#CC000000" CornerRadius="20" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Meu Carrinho" Foreground="#FF00F9FF" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListaCarrinho">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#33FFFFFF" Margin="0,5" Padding="10" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Source="{Binding CaminhoImagem}" Height="40" Width="40"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Nome}" Foreground="White" VerticalAlignment="Center" FontSize="14" Margin="10,0"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="-" Width="25" Height="25" Cursor="Hand" Click="BtnRemover_Click"/>
                                            <TextBlock Text="{Binding Quantidade}" Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
                                            <Button Content="+" Width="25" Height="25" Cursor="Hand" Click="BtnAdicionar_Click"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{Binding PreçoTotal, StringFormat='R$ {0:F2}'}" Foreground="#FF00F9FF" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Separator Background="#33FFFFFF" Margin="0,10"/>
                    <Grid>
                        <TextBlock Text="Total do Pedido:" Foreground="White" FontSize="18"/>
                        <TextBlock x:Name="Txt_TotalGeral" Text="R$ 0,00" Foreground="#FF00F9FF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Button Content="FINALIZAR PEDIDO" Background="#FF00F9FF" Foreground="Black" FontWeight="Bold" Height="40" Margin="0,20,0,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>