<UserControl x:Class="Projeto_DrinksApp.UC_Carrinho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch">

    <UserControl.Resources>
        <Style x:Key="BotaoQuantidadeAzul" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Border Background="#CC000000" CornerRadius="20" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Meu Carrinho" 
                           Foreground="#FF00F9FF" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto" 
                              Padding="0,0,10,0">
                    <ItemsControl x:Name="ListaCarrinho" ItemsSource="{Binding}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1AFFFFFF" Margin="0,0,0,10" Padding="12" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding Nome}" 
                                                   Foreground="White" 
                                                   VerticalAlignment="Center" 
                                                   FontSize="15"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="-" 
                                                    Style="{StaticResource BotaoQuantidadeAzul}" 
                                                    Click="BtnRemover_Click"/>

                                            <TextBlock Text="{Binding Quantidade}" 
                                                       Foreground="White" 
                                                       FontSize="16"
                                                       MinWidth="30"
                                                       TextAlignment="Center"
                                                       Margin="8,0" 
                                                       VerticalAlignment="Center"/>

                                            <Button Content="+" 
                                                    Style="{StaticResource BotaoQuantidadeAzul}" 
                                                    Click="BtnAdicionar_Click"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding PrecoTotal, StringFormat='R$ {0:F2}'}" 
                                                   Foreground="#FF00F9FF" 
                                                   HorizontalAlignment="Right" 
                                                   VerticalAlignment="Center" 
                                                   FontSize="15"
                                                   FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                    <Separator Background="#33FFFFFF" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Total do Pedido:" Foreground="White" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock x:Name="Txt_TotalGeral" 
                                   Text="R$ 0,00" 
                                   Foreground="#FF00F9FF" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="FINALIZAR PEDIDO" 
                            Background="#FF00F9FF" 
                            Foreground="Black" 
                            FontWeight="Bold" 
                            FontSize="16"
                            Height="45" 
                            Cursor="Hand" 
                            Click="Button_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>