<UserControl x:Class="Projeto_DrinksApp.UC_Pedidos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <DataGrid x:Name="dgpedidos" 
          AutoGenerateColumns="False" 
          ItemsSource="{Binding}"
          Background="Transparent" 
          RowBackground="#22FFFFFF" 
          AlternatingRowBackground="#33FFFFFF" 
          Foreground="White" 
          BorderThickness="0" 
          CanUserAddRows="False"
          HeadersVisibility="Column"
          GridLinesVisibility="None">

        <DataGrid.Resources>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#11FFFFFF"/>
                <Setter Property="Foreground" Value="#FF00F9FF"/>
                <Setter Property="Padding" Value="10,5,10,5"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
        </DataGrid.Resources>

        <DataGrid.Columns>
            <DataGridTextColumn Header="Nº Pedido" Binding="{Binding IdPedido}" Width="80"/>
            <DataGridTextColumn Header="Data" Binding="{Binding DataPedido, StringFormat=dd/MM/yyyy}" Width="120"/>
            <DataGridTextColumn Header="Total" Binding="{Binding ValorTotal, StringFormat=C2}" Width="100">
                <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FF00F9FF"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Observação" Binding="{Binding Observacoes}" Width="*"/>
        </DataGrid.Columns>
    </DataGrid>
</UserControl>