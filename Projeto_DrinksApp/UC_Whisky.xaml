<UserControl x:Class="Projeto_DrinksApp.UC_Whisky"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch">
    <UserControl.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black" Offset="0"/>
            <GradientStop Color="#FF462E01" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Background>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="MENU DE WHISKY" Foreground="#FFFFA500" FontSize="24" HorizontalAlignment="Center" FontFamily="Sitka Subheading"/>
                <TextBlock Text="Os Melhores Rótulos" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,25"/>
                <WrapPanel HorizontalAlignment="Center">
                    <Border Background="#44000000" CornerRadius="10" Width="140" Height="190" Margin="10" BorderBrush="#FFFFA500" BorderThickness="1">
                        <StackPanel>
                            <Image Source="C:\Users\06233321085\Pictures/download-removebg-preview.png" Height="90" Margin="5"/>
                            <TextBlock Text="Jack Daniels" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock Text="R$ 140,00" Foreground="#FFFFA500" HorizontalAlignment="Center" Margin="5"/>
                            <Button Content="Comprar" Click="BtnComprar_Click" Tag="Jack Daniels" Uid="140.00" Background="#FF462E01" Foreground="White" Width="100" Margin="5"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>